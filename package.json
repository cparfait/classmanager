{
  "name": "classmanager-pro",
  "version": "1.1.0",
  "description": "ClassManager Pro - Gestion de placement d'élèves en classe",
  "main": "main.js",
  "author": "Cris Tof",
  "license": "GPL-3.0",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder --win",
    "build-portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.classmanager.pro",
    "productName": "ClassManager Pro",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.ico",
      "cris.jpg",
      "js/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "icon.ico",
      "shortcutName": "ClassManager Pro"
    },
    "portable": {
      "artifactName": "ClassManager-Pro-Portable-${version}.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "cparfait",
      "repo": "classmanager"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
